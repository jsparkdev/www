import Github from "~/assets/github.svg"
import BlueSky from "~/assets/bluesky.svg"
import Twitter from "~/assets/twitter.svg"
---
<nav class="flex flex-wrap gap-3">
  <Link href="https://github.com/jsparkdev" label='Github'>
    <Github size={32} />
