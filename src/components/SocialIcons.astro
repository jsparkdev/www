  <Link href="https://bsky.app/profile/jspark.dev" label='Bluesky'>
    <BlueSky size={32} />
  </Link>
  <Link href="https://x.com/jsparkdev" label='Twitter'>
    <Twitter size={32} />
  </Link>
</nav>
